{
  "name": "fastify-auto-sqlapi",
  "version": "0.0.1",
  "description": "Fastify plugin for automatic CRUD API generation from PostgreSQL, MySQL and MariaDB tables",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sqlapi-generate-schema": "./dist/bin/generate-schema.js",
    "sqlapi-generate-tables": "./dist/bin/generate-tables.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "AGENTS_BACKEND.md",
    "AGENTS_FRONTEND.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "npm run build && npm run test:unit",
    "test": "node --test test/unit/*.test.js test/integration/*.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "test:setup": "docker compose -f test/docker-compose.yml up -d --wait",
    "test:teardown": "docker compose -f test/docker-compose.yml down -v",
    "test:manual": "tsc -p test/manual/tsconfig.json && node test/manual/dist/server.js"
  },
  "keywords": [
    "fastify",
    "fastify-plugin",
    "postgresql",
    "mysql",
    "mariadb",
    "crud",
    "api",
    "sql",
    "rest",
    "auto",
    "codegen",
    "typebox"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Luca Rainone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaRainone/fastify-auto-sqlapi.git"
  },
  "bugs": {
    "url": "https://github.com/LucaRainone/fastify-auto-sqlapi/issues"
  },
  "homepage": "https://github.com/LucaRainone/fastify-auto-sqlapi#readme",
  "dependencies": {
    "@sinclair/typebox": "^0.34.14",
    "node-condition-builder": "^1.0.6"
  },
  "devDependencies": {
    "@fastify/postgres": "^6.0.2",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "fastify": "^5.7.4",
    "pg": "^8.13.1",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@fastify/mysql": ">=4.0.0",
    "@fastify/postgres": ">=5.0.0",
    "@fastify/swagger": ">=9.0.0",
    "@fastify/swagger-ui": ">=5.0.0",
    "fastify": ">=4.0.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "@fastify/postgres": {
      "optional": true
    },
    "@fastify/mysql": {
      "optional": true
    },
    "@fastify/swagger": {
      "optional": true
    },
    "@fastify/swagger-ui": {
      "optional": true
    }
  }
}
