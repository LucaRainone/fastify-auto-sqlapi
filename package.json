{
  "name": "fastify-auto-sqlapi",
  "version": "1.0.0",
  "description": "Fastify plugin for automatic CRUD API generation from PostgreSQL tables",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sqlapi-generate-schema": "./dist/bin/generate-schema.js"
  },
  "scripts": {
    "build": "tsc"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.14",
    "node-condition-builder": "^1.0.4",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  }
}
