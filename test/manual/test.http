### ─── Customer: base search ───────────────────────────────────

### All customers
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{}

### Filter by isActive

POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "filters": {
    "isActive": true
  }
}

### Full-text search (extraFilter q)

POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "filters": {
    "q": "mario"
  }
}

### Filter by name + isActive

POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "filters": {
    "name": "Mario Rossi",
    "isActive": true
  }
}

### ─── Customer: pagination ───────────────────────────────────

### Page 1, 2 items per page
POST http://localhost:3000/auto/search/customer?page=1&itemsPerPage=2
Content-Type: application/json

{}

### Page 2

POST http://localhost:3000/auto/search/customer?page=2&itemsPerPage=2
Content-Type: application/json

{}

### Pagination + compute aggregates

POST http://localhost:3000/auto/search/customer?page=1&itemsPerPage=10&computeMin=id&computeMax=id
Content-Type: application/json

{}

### ─── Customer: order by ─────────────────────────────────────

### Order by email DESC
POST http://localhost:3000/auto/search/customer?orderBy=email%20DESC
Content-Type: application/json

{}

### ─── Customer: joins ────────────────────────────────────────

### Join customer_order (no filters)
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joins": {
    "customer_order": {}
  }
}

### Join customer_order with filter on status
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joins": {
    "customer_order": {
      "filters": {
        "status": "completed"
      }
    }
  }
}

### Join + main filters combined
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "filters": {
    "isActive": true
  },
  "joins": {
    "customer_order": {
      "filters": {
        "status": "pending"
      }
    }
  }
}

### ─── Customer: joinGroups ───────────────────────────────────

### Sum totals per customer
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "sum": ["total"]
      }
    }
  }
}

### Multiple aggregations: sum, min, max on total
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "sum": ["total"],
        "min": ["total"],
        "max": ["total"]
      }
    }
  }
}

### distinctCount on status
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "distinctCount": ["status"]
      }
    }
  }
}

### Group by status
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "by": "status",
        "sum": ["total"]
      }
    }
  }
}

### joinGroups with filters
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "sum": ["total"],
        "max": ["total"]
      },
      "filters": {
        "status": "completed"
      }
    }
  }
}

### ─── Customer: joins + joinGroups combined ──────────────────

### Full: filters + joins + joinGroups + pagination
POST http://localhost:3000/auto/search/customer?page=1&itemsPerPage=10
Content-Type: application/json

{
  "filters": {
    "isActive": true
  },
  "joins": {
    "customer_order": {}
  },
  "joinGroups": {
    "customer_order": {
      "aggregations": {
        "sum": ["total"],
        "min": ["total"],
        "max": ["total"],
        "distinctCount": ["status"]
      }
    }
  }
}

### ─── CustomerOrder: base search ─────────────────────────────

### All orders
POST http://localhost:3000/auto/search/customer_order
Content-Type: application/json

{}

### Filter by status
POST http://localhost:3000/auto/search/customer_order
Content-Type: application/json

{
  "filters": {
    "status": "completed"
  }
}

### Filter by customerId
POST http://localhost:3000/auto/search/customer_order
Content-Type: application/json

{
  "filters": {
    "customerId": 1
  }
}

### ─── Product: base search ───────────────────────────────────

### All products
POST http://localhost:3000/auto/search/product
Content-Type: application/json

{}

### Filter by isAvailable
POST http://localhost:3000/auto/search/product
Content-Type: application/json

{
  "filters": {
    "isAvailable": true
  }
}

### Filter by name
POST http://localhost:3000/auto/search/product
Content-Type: application/json

{
  "filters": {
    "name": "Widget"
  }
}

### ─── Insert: customer ────────────────────────────────────────

### Insert customer (main only)
POST http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "name": "Nuovo Cliente",
    "email": "nuovo@test.it",
    "phoneNumber": "123456789",
    "isActive": true
  }
}

### Insert customer + orders (main + secondaries)
POST http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "name": "Cliente con Ordini",
    "email": "ordini@test.it",
    "phoneNumber": "987654321",
    "isActive": true
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 150.00,
        "status": "pending",
        "orderDate": "2024-06-01"
      },
      {
        "total": 250.00,
        "status": "completed",
        "orderDate": "2024-06-15"
      }
    ]
  }
}

### Insert customer order (standalone)
POST http://localhost:3000/auto/rest/customer_order
Content-Type: application/json

{
  "main": {
    "customerId": 1,
    "total": 99.99,
    "status": "pending",
    "orderDate": "2024-07-01"
  }
}

### ─── Update: customer ──────────────────────────────────────

### Update customer (main only)
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Nome Aggiornato",
    "phoneNumber": "000000000"
  }
}

### Update customer + add secondary orders
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Cliente Aggiornato"
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 500.00,
        "status": "pending",
        "orderDate": "2024-08-01"
      }
    ]
  }
}

### Update customer + delete secondary orders
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Cliente Aggiornato"
  },
  "deletions": {
    "customer_order": [
      { "id": 5 }
    ]
  }
}

### Update customer + secondaries + deletions
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Full Update"
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 300.00,
        "status": "new",
        "orderDate": "2024-09-01"
      }
    ]
  },
  "deletions": {
    "customer_order": [
      { "id": 10 }
    ]
  }
}
