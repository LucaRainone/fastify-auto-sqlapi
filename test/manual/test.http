### ─── Insert: customer ────────────────────────────────────────

### Insert customer (main only)
POST http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "name": "Nuovo Cliente",
    "email": "nuovo@test.it",
    "phoneNumber": "123456789",
    "isActive": true
  }
}

### Insert customer + orders (main + secondaries)
POST http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "name": "Cliente con Ordini",
    "email": "ordini@test.it",
    "phoneNumber": "987654321",
    "isActive": true
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 150.00,
        "status": "pending",
        "orderDate": "2024-06-01"
      },
      {
        "total": 250.00,
        "status": "completed",
        "orderDate": "2024-06-15"
      }
    ]
  }
}

### Insert customer order (standalone)
POST http://localhost:3000/auto/rest/customer_order
Content-Type: application/json

{
  "main": {
    "customerId": 1,
    "total": 99.99,
    "status": "pending",
    "orderDate": "2024-07-01"
  }
}

### ─── Update: customer ──────────────────────────────────────

### Update customer (main only)
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Nome Aggiornato",
    "phoneNumber": "000000000"
  }
}

### Update customer + add secondary orders
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Cliente Aggiornato"
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 500.00,
        "status": "pending",
        "orderDate": "2024-08-01"
      }
    ]
  }
}

### Update customer + delete secondary orders
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Cliente Aggiornato"
  },
  "deletions": {
    "customer_order": [
      { "id": 5 }
    ]
  }
}

### ─── Get: single record ────────────────────────────────────

### Get customer by id
GET http://localhost:3000/auto/rest/customer/1

### Get order by id
GET http://localhost:3000/auto/rest/customer_order/3

### Get non-existing record (404)
GET http://localhost:3000/auto/rest/customer/99999

### ─── Delete: customer ──────────────────────────────────────

### Delete customer by id
DELETE http://localhost:3000/auto/rest/customer/1

### Delete order by id
DELETE http://localhost:3000/auto/rest/customer_order/5

### ─── Update: secondaries + deletions ───────────────────────

### Update customer + secondaries + deletions
PUT http://localhost:3000/auto/rest/customer
Content-Type: application/json

{
  "main": {
    "id": 1,
    "name": "Full Update"
  },
  "secondaries": {
    "customer_order": [
      {
        "total": 300.00,
        "status": "new",
        "orderDate": "2024-09-01"
      }
    ]
  },
  "deletions": {
    "customer_order": [
      { "id": 10 }
    ]
  }
}

### ─── Bulk Upsert: customer ─────────────────────────────────

### Bulk upsert multiple customers (main only)
PUT http://localhost:3000/auto/bulk/customer
Content-Type: application/json

[
  {
    "main": {
      "name": "Bulk Customer 1",
      "email": "bulk1@test.it",
      "phoneNumber": "111111",
      "isActive": true
    }
  },
  {
    "main": {
      "name": "Bulk Customer 2",
      "email": "bulk2@test.it",
      "phoneNumber": "222222",
      "isActive": true
    }
  }
]

### Bulk upsert with secondaries
PUT http://localhost:3000/auto/bulk/customer
Content-Type: application/json

[
  {
    "main": {
      "name": "Cliente con Ordini Bulk",
      "email": "bulk-orders@test.it",
      "phoneNumber": "333333",
      "isActive": true
    },
    "secondaries": {
      "customer_order": [
        { "total": 100.00, "status": "pending", "orderDate": "2024-10-01" },
        { "total": 200.00, "status": "completed", "orderDate": "2024-10-15" }
      ]
    }
  }
]

### Bulk upsert with secondaries + deletions
PUT http://localhost:3000/auto/bulk/customer
Content-Type: application/json

[
  {
    "main": {
      "id": 1,
      "name": "Update via Bulk",
      "email": "updated@test.it"
    },
    "secondaries": {
      "customer_order": [
        { "total": 500.00, "status": "new", "orderDate": "2024-11-01" }
      ]
    },
    "deletions": {
      "customer_order": [
        { "id": 10 }
      ]
    }
  },
  {
    "main": {
      "name": "Nuovo via Bulk",
      "email": "nuovo-bulk@test.it"
    }
  }
]

### ─── Bulk Delete: customer ───────────────────────────────────

### Bulk delete multiple customers by id
POST http://localhost:3000/auto/bulk/customer/delete
Content-Type: application/json

[
  { "id": 10 },
  { "id": 11 }
]

###########################################################################
#                     MULTI-TENANT FILTERING
#
# Header X-Tenant-Id controlla il tenant:
#   - assente     → admin (nessun filtro, vede tutto)
#   - "1"         → filtra per organization_id = 1
#   - "1,2"       → filtra per organization_id IN (1, 2)
#
# customer:       tenant DIRETTO   (colonna organization_id sulla tabella)
# customer_order: tenant INDIRETTO (via INNER JOIN su customer.organization_id)
# product:        nessun tenant    (sempre visibile a tutti)
###########################################################################

### ─── Tenant: search (diretto) ──────────────────────────────

### Admin: tutti i customer (no header X-Tenant-Id)
POST http://localhost:3000/auto/search/customer
Content-Type: application/json

{}

### Tenant 1: solo customer dell'organizzazione 1
POST http://localhost:3000/auto/search/customer
Content-Type: application/json
X-Tenant-Id: 1

{}

### Tenant 2: solo customer dell'organizzazione 2
POST http://localhost:3000/auto/search/customer
Content-Type: application/json
X-Tenant-Id: 2

{}

### Multi-tenant: customer delle organizzazioni 1 e 2
POST http://localhost:3000/auto/search/customer
Content-Type: application/json
X-Tenant-Id: 1,2

{}

### Tenant + filtri combinati
POST http://localhost:3000/auto/search/customer
Content-Type: application/json
X-Tenant-Id: 1

{
  "filters": {
    "isActive": true
  }
}

### Tenant + pagination
POST http://localhost:3000/auto/search/customer?page=1&itemsPerPage=2
Content-Type: application/json
X-Tenant-Id: 1

{}

### ─── Tenant: search (indiretto) ────────────────────────────

### Tenant 1: ordini dei customer dell'organizzazione 1 (INNER JOIN)
POST http://localhost:3000/auto/search/customer_order
Content-Type: application/json
X-Tenant-Id: 1

{}

### Admin: tutti gli ordini (no header)
POST http://localhost:3000/auto/search/customer_order
Content-Type: application/json

{}

### ─── Tenant: search product (no tenant scope) ──────────────

### Tutti i prodotti anche con header (product non ha tenantScope)
POST http://localhost:3000/auto/search/product
Content-Type: application/json
X-Tenant-Id: 1

{}

### ─── Tenant: get (diretto) ─────────────────────────────────

### Admin: get customer 1 (vede tutto)
GET http://localhost:3000/auto/rest/customer/1

### Tenant 1: get customer 1 (solo se appartiene a org 1, altrimenti 404)
GET http://localhost:3000/auto/rest/customer/1
X-Tenant-Id: 1

### Tenant 99: get customer 1 (404 — non appartiene a org 99)
GET http://localhost:3000/auto/rest/customer/1
X-Tenant-Id: 99

